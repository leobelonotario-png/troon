generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Domicile {
  ONSHORE
  OFFSHORE
}

enum FundOrigin {
  APPROVED
  INDUSTRY
}

enum FundType {
  LIQUID
  ILLIQUID
  LISTED
}

enum FundStatus {
  OPEN
  CLOSED
}

enum AssetClass {
  FLOATING_RATE
  SHORT_DURATION
  LONG_DURATION
  HEDGE_FUNDS
  EQUITIES
  ALTERNATIVES
  FII_BRICK_AND_MORTAR
  FII_PAPER
  FII_HYBRID
  FII_FOFS
  ETF
}

enum Subtype {
  OVERNIGHT
  HIGH_GRADE
  HIGH_YIELD
  SD_SOVEREIGN
  LD_SOVEREIGN
  MACRO
  MULTI_STRATEGY
  LONG_AND_SHORT
  LARGE_CAP_VALUE
  MID_CAP_VALUE
  SMALL_CAP_VALUE
  LARGE_CAP_BLEND
  MID_CAP_BLEND
  SMALL_CAP_BLEND
  LARGE_CAP_GROWTH
  MID_CAP_GROWTH
  SMALL_CAP_GROWTH
  LONG_BIASED
  SECONDARIES
  STRUCTURED_CREDIT
  SPECIAL_SITUATION
  PRIVATE_EQUITY
  GROWTH_CAPITAL
  VENTURE_CAPITAL
  PUBLIC_INFRASTRUCTURE
  PUBLIC_REAL_ESTATE
  PRIVATE_REAL_ESTATE
  GOLD
  CURRENCY
  CRYPTOCURRENCY
  COMMODITIES
  LOGISTICS
  CORPORATE_OFFICES
  SHOPPING
  URBAN_INCOME
  INDUSTRIAL
  HOSPITALITY
  RESIDENTIAL
  AGRICULTURE
  DEVELOPMENT
  OTHER
  HYBRID
  FOF
  EQUITIES
  FIXED_INCOME_SECURITIES
  FACTORS
  SECTORAL
  THEMATIC
  ASSETS
  DIGITAL_ASSETS
}

model Fund {
  id                                      String      @id @default(cuid())
  classCode                               String      @unique
  name                                    String
  origin                                  FundOrigin  @default(APPROVED)
  fundRegistrationNumber                  String?
  managerName                             String?
  managerRegistrationNumber               String?
  anbimaCategory                          String?
  netAssetsBillions                       Float?
  investorCount                           Int?
  trailingTwelveMonthsReturn              Float?
  sharePrice                              Float?
  sharePriceDate                          DateTime?
  domicile                                Domicile?
  fundType                                FundType?
  status                                  FundStatus?
  assetClass                              AssetClass?
  subtype                                 Subtype?
  annualizedReturnSinceInception          Float?
  annualizedVolatilitySinceInception      Float?
  validated                               Boolean?
  lastImportedAt                          DateTime?
  benchmark                               String?
  liquidity                               String?
  taxation                                String?
  data                                    String?
  recommended                             Boolean     @default(false)
  quantitativeRating                      Float?
  finalRating                             Float?
  notes                                   String?
  color                                   String?
  createdAt                               DateTime    @default(now())
  updatedAt                               DateTime    @updatedAt

  @@index([validated])
  @@index([fundType, assetClass, subtype])
  @@index([fundRegistrationNumber])
  @@index([name])
}

model Index {
  id        String   @id @default(cuid())
  name      String
  ret       Float?
  vol       Float?
  updatedAt DateTime @updatedAt
  color     String?
  dashed    Boolean  @default(false)
}

model Comparison {
  id          String   @id @default("default")
  refId       String?
  selected    Json
  title       String
  source      String
  period      String
  correlations Json
  updatedAt   DateTime @updatedAt
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}
